# Vigía — copia a `.env` y rellena. Se lee al arrancar: cambios => reiniciar.
# Línea comentada = valor por defecto; descomenta solo lo que cambies.
# No pongas comentarios en la misma línea que un valor.

# Token Data API: app.travelpayouts.com > Profile > API token
VIGIA_TRAVELPAYOUTS_TOKEN=

# Telegram: token de @BotFather + tu chat_id (te lo da @userinfobot)
VIGIA_TELEGRAM_BOT_TOKEN=
VIGIA_TELEGRAM_CHAT_ID=

# Origen (IATA) y presupuestos en EUR:
#   BUDGET_CAP      = detección, SOLO vuelos (ida+vuelta x pax); el chollo
#                     absoluto dispara al 60% de esto
#   TRIP_BUDGET_CAP = tope del viaje completo (vuelos + hotel)
#VIGIA_ORIGIN=ALC
#VIGIA_BUDGET_CAP=600
#VIGIA_TRIP_BUDGET_CAP=600
#VIGIA_PAX=2

# Noches del viaje que interesan y horizonte de vigilancia (~11 meses)
#VIGIA_TRIP_MIN_NIGHTS=2
#VIGIA_TRIP_MAX_NIGHTS=14
#VIGIA_WINDOW_DAYS=330
#VIGIA_DISCOVERY=true

# Filtros de destino: países a excluir (ISO, separados por coma) y duración
# máxima del vuelo de ida en horas (escalas incluidas)
#VIGIA_EXCLUDE_COUNTRIES=ES
#VIGIA_MAX_FLIGHT_HOURS=4

# Ventanas de viaje por calendario (vacío = desactivado). Hasta esa fecha:
# viajes de MIN-MAX noches cualquier día; desde esa fecha: solo findes y
# puentes (festivos de España + region; extras = fiestas locales, ej. Hogueras)
#VIGIA_WEEKEND_ONLY_AFTER=2026-09-06
#VIGIA_PRE_WEEKEND_NIGHTS_MIN=4
#VIGIA_PRE_WEEKEND_NIGHTS_MAX=5
#VIGIA_HOLIDAYS_REGION=VC
#VIGIA_EXTRA_HOLIDAYS=

# Hoteles: 'none' (solo vuelos) o 'liteapi'. La key sand_... da precios de
# PRUEBA; para precios reales, tarjeta en liteapi.travel y key de producción.
VIGIA_HOTEL_SOURCE=none
VIGIA_LITEAPI_KEY=

# Sensibilidad de la detección (calibrar tras semanas de datos)
#VIGIA_MIN_DROP_PCT=0.20
#VIGIA_Z_THRESHOLD=2.0
#VIGIA_HARD_STEAL_RATIO=0.60
#VIGIA_MIN_SAMPLE=8
#VIGIA_REALERT_DROP=0.10

# Ritmo del barrido (los defaults respetan los rate limits)
#VIGIA_TICK_INTERVAL_S=300
#VIGIA_BATCH_SIZE=20
#VIGIA_MAX_QUOTES_PER_PAIR=5

# DB: en Docker /data/vigia.db (volumen persistente); en local ./vigia.db
#VIGIA_DB_PATH=/data/vigia.db

# Email opcional: smtp://user:pass@host:587 o smtps://user:pass@host:465
#VIGIA_SMTP_URL=
#VIGIA_ALERT_EMAIL_TO=

# Capa 2: re-cotiza los candidatos en vivo (Duffel) antes de avisar.
# Requiere token duffel_live_ (el de test da inventario ficticio).
# Coste: 0,005 $/busqueda pasado el ratio 1500:1 — solo se usa en candidatos.
#VIGIA_ENABLE_PRICE_CONFIRMER=false
#VIGIA_DUFFEL_TOKEN=

# Moneda/mercado de Travelpayouts y modo hotel (defaults sensatos)
#VIGIA_CURRENCY=eur
#VIGIA_MARKET=es
#VIGIA_HOTEL_MODE=candidates

# Hora (UTC) del digest diario opcional (se activa con /digest on en Telegram)
#VIGIA_DIGEST_HOUR=9
